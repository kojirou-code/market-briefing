---
title: "{{ title }}"
date: {{ date_iso }}
draft: false
description: "{{ description }}"
tags: ["daily", "market"]
---

{%- if alerts %}
<div class="alert-box">

{% for alert in alerts %}
**{{ alert.emoji }} {{ alert.message }}**
{% endfor %}

</div>
{%- endif %}

## ダッシュボード

<div class="market-grid">
<div class="market-card">

### 🇺🇸 米国市場

{% for idx in us_indices %}
<div class="market-row">
<span class="market-name">{{ idx.display_name }}</span>
<span class="market-value">
  {%- if idx.error -%}
  <span style="color:gray;">取得失敗</span>
  {%- else -%}
  {{ "%.2f"|format(idx.close) if idx.close else "—" }}
  <span class="{{ 'change-positive' if idx.change_pct and idx.change_pct > 0 else 'change-negative' if idx.change_pct and idx.change_pct < 0 else 'change-neutral' }}">
    {{ "%+.2f%%"|format(idx.change_pct) if idx.change_pct is not none else "—" }}
  </span>
  {{ idx.signal }}
  {%- endif -%}
</span>
</div>
{% endfor %}

</div>
<div class="market-card">

### 🇯🇵 日本市場

{% for idx in jp_indices %}
<div class="market-row">
<span class="market-name">{{ idx.display_name }}</span>
<span class="market-value">
  {%- if idx.error -%}
  <span style="color:gray;">取得失敗</span>
  {%- else -%}
  {{ "%.2f"|format(idx.close) if idx.close else "—" }}
  <span class="{{ 'change-positive' if idx.change_pct and idx.change_pct > 0 else 'change-negative' if idx.change_pct and idx.change_pct < 0 else 'change-neutral' }}">
    {{ "%+.2f%%"|format(idx.change_pct) if idx.change_pct is not none else "—" }}
  </span>
  {{ idx.signal }}
  {%- endif -%}
</span>
</div>
{% endfor %}

</div>
</div>

### 📊 主要指標

<div class="indicators-row">
{% for ind in indicators %}
<div class="indicator-item">
<span class="indicator-label">{{ ind.display_name }}</span>
<span class="indicator-value">
  {%- if ind.error -%}—
  {%- elif ind.name == "USDJPY" -%}{{ "%.2f"|format(ind.value) if ind.value else "—" }}
  {%- elif ind.name == "US10Y" -%}{{ "%.2f%%"|format(ind.value) if ind.value else "—" }}
  {%- else -%}{{ "%.2f"|format(ind.value) if ind.value else "—" }}{% if ind.signal is defined %} {{ ind.signal }}{% endif %}
  {%- endif -%}
</span>
{% if ind.change_pct is not none %}
<span class="indicator-label {{ 'change-positive' if ind.change_pct > 0 else 'change-negative' if ind.change_pct < 0 else 'change-neutral' }}">
  {{ "%+.2f%%"|format(ind.change_pct) }}
</span>
{% endif %}
</div>
{% endfor %}

{%- if fear_greed and not fear_greed.error %}
<div class="indicator-item">
<span class="indicator-label">Fear & Greed</span>
<span class="indicator-value">{{ fear_greed.score }} {{ fear_greed.emoji }}</span>
<span class="indicator-label">{{ fear_greed.label }}</span>
</div>
{%- endif %}
</div>

### 🔮 先物・コモディティ

<div class="indicators-row">
{% for fc in futures_commodities %}
<div class="indicator-item">
<span class="indicator-label">{{ fc.display_name }}</span>
<span class="indicator-value">
  {%- if fc.error -%}—
  {%- else -%}{{ "%.2f"|format(fc.value) if fc.value else "—" }}
  {%- endif -%}
</span>
{% if fc.change_pct is not none %}
<span class="indicator-label {{ 'change-positive' if fc.change_pct > 0 else 'change-negative' if fc.change_pct < 0 else 'change-neutral' }}">
  {{ "%+.2f%%"|format(fc.change_pct) }}
</span>
{% endif %}
</div>
{% endfor %}
</div>

{%- if direction_score %}
### 🧭 方向性推定

<div class="indicators-row">
<div class="indicator-item">
<span class="indicator-label">米国</span>
<span class="indicator-value">{{ direction_score.us.emoji }} {{ direction_score.us.label }}</span>
<span class="indicator-label" style="font-size:0.75rem;">スコア {{ "%+d"|format(direction_score.us.score) }}/10</span>
</div>
<div class="indicator-item">
<span class="indicator-label">日本</span>
<span class="indicator-value">{{ direction_score.jp.emoji }} {{ direction_score.jp.label }}</span>
<span class="indicator-label" style="font-size:0.75rem;">スコア {{ "%+d"|format(direction_score.jp.score) }}/10</span>
</div>
<div class="indicator-item">
<span class="indicator-label">総合</span>
<span class="indicator-value">{{ direction_score.overall.emoji }} {{ direction_score.overall.label }}</span>
<span class="indicator-label" style="font-size:0.75rem;">スコア {{ "%+d"|format(direction_score.overall.score) }}/10</span>
</div>
</div>
{%- endif %}

---

### 📅 今週の重要イベント

{% if calendar_events %}
<ul class="calendar-list">
{% for ev in calendar_events %}
<li>
<span class="calendar-date">{{ ev.date_str }}({{ ev.weekday }})</span>
<span>{{ "🇺🇸" if ev.country == "US" else "🇯🇵" if ev.country == "JP" else "" }} {{ ev.event }}</span>
{% if ev.importance == "high" %}<span style="color:#ef4444;font-size:0.75rem;"> ★重要</span>{% endif %}
</li>
{% endfor %}
</ul>
{% else %}
<p style="color:gray;">直近イベントなし</p>
{% endif %}

---

### 📰 注目ニュース

{%- if news_summary %}
{# Geminiサマリーが利用可能な場合 #}
<div class="news-summary">

<div class="summary-conclusion">

**📌 本日の結論**

{{ news_summary.conclusion }}

</div>

{%- if news_summary.political_news %}
<details class="detail-section" open>
<summary>🗳️ 政治・地政学ニュース</summary>

{% for item in news_summary.political_news %}
<div class="news-card">

**{{ item.headline }}**
<span class="risk-{{ 'high' if item.risk_level == '高' else 'mid' if item.risk_level == '中' else 'low' }}" style="font-size:0.75rem;margin-left:0.5rem;">リスク: {{ item.risk_level }}</span>

{{ item.what_happened }}

*影響: {{ item.why_important }}*

<span class="news-source" style="font-size:0.75rem;color:gray;">{{ item.source }}</span>

</div>
{% endfor %}

</details>
{%- endif %}

{%- if news_summary.economic_news %}
<details class="detail-section" open>
<summary>📊 経済・金融ニュース</summary>

{% for item in news_summary.economic_news %}
<div class="news-card">

**{{ item.headline }}**

{{ item.facts }}

米国: {{ item.us_market_impact }} / 日本: {{ item.jp_market_impact }}

<span class="news-source" style="font-size:0.75rem;color:gray;">{{ item.source }}</span>

</div>
{% endfor %}

</details>
{%- endif %}

{%- if news_summary.market_perspective %}
<details class="detail-section" open>
<summary>🌏 日米マーケット視点</summary>

| 市場 | サマリー |
|------|---------|
| 🇺🇸 米国 | {{ news_summary.market_perspective.us_summary }} |
| 🇯🇵 日本 | {{ news_summary.market_perspective.jp_summary }} |
| 🔗 連動 | {{ news_summary.market_perspective.us_jp_linkage }} |

</details>
{%- endif %}

</div>

{%- else %}
{# フォールバック: 通常のTOP5表示 #}
{% if news_error %}
<p style="color:gray;">ニュース取得失敗</p>
{% elif news_top5 %}
<ol class="news-list">
{% for item in news_top5 %}
<li>
{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}
<span class="news-source">（{{ item.source }}）</span>
</li>
{% endfor %}
</ol>
{% else %}
<p style="color:gray;">ニュースなし</p>
{% endif %}
{%- endif %}

---

{%- if sector_data and not sector_data.error %}
<details class="detail-section">
<summary>▼ セクター騰落ランキング（米国）</summary>

<table class="tech-table">
<thead>
<tr><th>順位</th><th>セクター</th><th>ETF</th><th>騰落率</th><th>信号</th></tr>
</thead>
<tbody>
{% for s in sector_data.sectors %}
<tr>
<td>{{ s.rank }}</td>
<td>{{ s.name }}</td>
<td style="font-size:0.8rem;color:gray;">{{ s.ticker }}</td>
<td class="{{ 'change-positive' if s.change_pct and s.change_pct > 0 else 'change-negative' if s.change_pct and s.change_pct < 0 else 'change-neutral' }}">
  {%- if s.error -%}—{%- else -%}{{ "%+.2f%%"|format(s.change_pct) if s.change_pct is not none else "—" }}{%- endif -%}
</td>
<td>{{ s.signal }}</td>
</tr>
{% endfor %}
</tbody>
</table>

</details>
{%- endif %}

<details class="detail-section">
<summary>▼ テクニカル詳細</summary>

### 米国市場テクニカル

{% for tech in us_technical %}
{% if not tech.error %}
#### {{ tech.name }}

{%- set _us_ticker = us_indices[loop.index0].ticker if us_indices|length > loop.index0 else None %}
{%- set _us_pair = chart_urls.get(_us_ticker, {}) if chart_urls and _us_ticker else {} %}
{%- if _us_pair %}
<div style="display:flex;gap:8px;flex-wrap:wrap;margin:8px 0;">
  {%- if _us_pair.get("daily") %}
  <div style="flex:1;min-width:280px;">
    <img src="{{ _us_pair.get('daily') }}" alt="{{ tech.name }} 日次チャート（1年）" style="width:100%;border-radius:4px;">
    <p style="font-size:0.7rem;color:gray;text-align:center;margin:2px 0;">日次・1年（SMA5/25/75）</p>
  </div>
  {%- endif %}
  {%- if _us_pair.get("weekly") %}
  <div style="flex:1;min-width:280px;">
    <img src="{{ _us_pair.get('weekly') }}" alt="{{ tech.name }} 週次チャート（3年）" style="width:100%;border-radius:4px;">
    <p style="font-size:0.7rem;color:gray;text-align:center;margin:2px 0;">週次・3年（SMA13/26/52）</p>
  </div>
  {%- endif %}
</div>
{%- endif %}

<table class="tech-table">
<thead>
<tr><th>指標</th><th>シグナル</th><th>値</th></tr>
</thead>
<tbody>
<tr>
<td>移動平均線 (SMA 5/25/75)</td>
<td>{{ tech.sma.signal }}</td>
<td style="font-size:0.8rem;">
  5: {{ "%.1f"|format(tech.sma.sma5) if tech.sma.sma5 else "—" }} /
  25: {{ "%.1f"|format(tech.sma.sma25) if tech.sma.sma25 else "—" }} /
  75: {{ "%.1f"|format(tech.sma.sma75) if tech.sma.sma75 else "—" }}
</td>
</tr>
<tr>
<td>RSI (14)</td>
<td>{{ tech.rsi.signal }}</td>
<td>{{ "%.1f"|format(tech.rsi.value) if tech.rsi.value else "—" }}</td>
</tr>
<tr>
<td>MACD (12,26,9)</td>
<td>{{ tech.macd.signal }}</td>
<td style="font-size:0.8rem;">
  MACD: {{ "%.2f"|format(tech.macd.macd) if tech.macd.macd else "—" }} /
  Signal: {{ "%.2f"|format(tech.macd.macd_signal) if tech.macd.macd_signal else "—" }}
</td>
</tr>
<tr>
<td>ボリンジャーバンド (20,2σ)</td>
<td>{{ tech.bb.signal }}</td>
<td style="font-size:0.8rem;">
  上: {{ "%.1f"|format(tech.bb.upper) if tech.bb.upper else "—" }} /
  下: {{ "%.1f"|format(tech.bb.lower) if tech.bb.lower else "—" }}
</td>
</tr>
<tr>
<td>出来高 (20MA比)</td>
<td>{{ tech.volume.signal }}</td>
<td>{{ "%.2f"|format(tech.volume.ratio) if tech.volume.ratio else "—" }}倍</td>
</tr>
</tbody>
</table>

{% else %}
#### {{ tech.name }}

<p style="color:gray;">テクニカルデータ取得失敗</p>

{% endif %}
{% endfor %}

